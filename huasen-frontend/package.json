{
  "name": "huasen-frontend",
  "private": true,
  "workspaces": [
    "portal",
    "admin",
    "packages/*"
  ],
  "scripts": {
    "serve:portal": "npm run serve --workspace portal",
    "serve:admin": "npm run serve --workspace admin",
    "build:portal": "npm run build --workspace portal",
    "build:admin": "npm run build --workspace admin",
    "build": "npm run build:portal && npm run build:admin",
    "lint:portal": "npm run lint --workspace portal",
    "lint:admin": "npm run lint --workspace admin",
    "lint": "npm run lint:portal && npm run lint:admin"
  },
  "dependencies": {
    "animate.css": "4.1.1",
    "axios": "0.21.1",
    "core-js": "3.39.0",
    "element-ui": "2.15.5",
    "mockjs2": "1.0.8",
    "nprogress": "0.2.0",
    "sass": "1.26.5",
    "showdown": "1.9.1",
    "vue": "2.6.11",
    "vue-i18n": "8.25.0",
    "vue-router": "3.5.2",
    "vuex": "3.6.2",
    "webpack-spritesmith": "1.1.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "4.5.0",
    "@vue/cli-plugin-eslint": "4.5.0",
    "@vue/cli-service": "4.5.0",
    "autoprefixer": "9.8.8",
    "babel-eslint": "10.1.0",
    "cross-env": "7.0.3",
    "eslint": "6.7.2",
    "eslint-plugin-vue": "6.2.2",
    "postcss": "7.0.39",
    "sass-loader": "7.3.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat@2.2.17",
    "vue-template-compiler": "2.6.11"
  }
}
